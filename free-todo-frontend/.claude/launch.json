{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Next.js 3001)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev:frontend:web"],
      "port": 3001,
      "autoPort": true,
      "env": {
        "NEXT_PUBLIC_API_URL": "http://localhost:8001"
      }
    },
    {
      "name": "Backend (FastAPI 8001)",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "lifetrace/scripts/start_backend.py"],
      "port": 8001
    }
  ]
}
